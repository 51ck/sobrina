# Sobri env names only — copy to `.env` and fill locally. Never commit secrets.
# See tech/foundation-tasks.md (T4) and tech/architecture.md (Env / secrets).
#
# Required vs optional (foundation boot = config + DB; live bot / agent later):
#   DATABASE_PATH       — REQUIRED for foundation boot (loadFoundationConfig)
#   TELEGRAM_BOT_TOKEN  — optional until live Grammy bot
#   MODEL_ID            — optional until agent board
#   Provider API key(s) — optional until agent board (exact name(s) locked there)
#   Bot admin allowlist — optional until /settings (exact name locked there)

# REQUIRED — foundation
DATABASE_PATH=

# Optional — later boards
TELEGRAM_BOT_TOKEN=
MODEL_ID=
# Provider API key name(s) locked on agent board — leave unset until then.
# Bot admin allowlist env name locked when /settings lands — leave unset until then.
